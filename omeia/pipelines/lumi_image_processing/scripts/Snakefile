def infer_project_root_from_base(base):
    parts = base.parts
    if "image_processing" in parts:
        idx = parts.index("image_processing")
        if idx > 0:
            return Path(*parts[:idx]).resolve()
    for i, part in enumerate(parts):
        if part.startswith("project_"):
            return Path(*parts[:i + 1]).resolve()
    return base.resolve()


