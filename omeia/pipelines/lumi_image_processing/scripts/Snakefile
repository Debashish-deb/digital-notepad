###############################################################################
# Channel and marker loading from data/channels_quantification.csv
###############################################################################

def read_channels_quantification_csv(path):
    path = Path(path)

    if not path.exists():
        return []

    channels = []

    with path.open("r", encoding="utf-8-sig", newline="") as handle:
        reader = csv.reader(handle)

        for row in reader:
            if not row:
                continue

            channel = row[0].strip()

            if channel.lower() in {
                "channel",
                "channels",
                "marker",
                "markers",
                "name",
                "channel_name",
                "marker_name",
            }:
                continue

            if channel:
                channels.append(channel)

    return channels


CHANNELS = read_channels_quantification_csv(CHANNELS_QUANTIFICATION_CSV)
CHANNEL_NAME_TO_INDEX = {name: idx for idx, name in enumerate(CHANNELS)}


def should_exclude_channel(channel_name):
    name = str(channel_name).strip()
    lower = name.lower()

    if not name:
        return True

    if lower.startswith("dapi"):
        return True

    if "background" in lower:
        return True

    if "_failed" in lower or lower.endswith("failed"):
        return True

    return False


def load_marker_channel_map():
    if not CHANNELS:
        print(
            f"[pipeline warning] Channel file missing or empty: "
            f"{CHANNELS_QUANTIFICATION_CSV}"
        )
        return {}

    markers = {}

    for idx, channel in enumerate(CHANNELS):
        if should_exclude_channel(channel):
            continue

        if channel in markers:
            raise ValueError(
                f"Duplicate biological marker in {CHANNELS_QUANTIFICATION_CSV}: "
                f"{channel}"
            )

        markers[channel] = idx

    if markers:
        print(f"[pipeline] Loaded channel list from: {CHANNELS_QUANTIFICATION_CSV}")
        print(f"[pipeline] Biological markers detected: {len(markers)}")
        print("[pipeline] Marker order: " + ", ".join(markers.keys()))
        return markers

    print(
        f"[pipeline warning] No biological markers detected in: "
        f"{CHANNELS_QUANTIFICATION_CSV}"
    )
    return {}


MARKER_CHANNEL_MAP = load_marker_channel_map()
BIOLOGICAL_MARKERS = list(MARKER_CHANNEL_MAP.keys())

# Critical: overwrite stale MARKERS_JSON from pipeline_config.sh.
# rules/filtering.smk reads MARKERS_JSON at include time.
MARKERS_JSON = json.dumps(MARKER_CHANNEL_MAP, ensure_ascii=False)
os.environ["MARKERS_JSON"] = MARKERS_JSON
os.environ["PIPELINE_MARKERS_JSON_OVERRIDE"] = MARKERS_JSON
os.environ["PIPELINE_MARKERS_SOURCE"] = str(CHANNELS_QUANTIFICATION_CSV)


###############################################################################
# Segmentation channel sanity/defaults
###############################################################################

def channel_name_at(index):
    try:
        return CHANNELS[int(index)]
    except Exception:
        return ""


def first_existing_channel(*names):
    for name in names:
        if name in CHANNEL_NAME_TO_INDEX:
            return CHANNEL_NAME_TO_INDEX[name]
    return None


def first_marker_alias(*aliases):
    normalized_aliases = [
        re.sub(r"[^a-z0-9]+", "", alias.lower())
        for alias in aliases
    ]
    for idx, name in enumerate(CHANNELS):
        lower_name = name.lower()
        if any(
            token in lower_name
            for token in ("background", "failed", "blank", "empty")
        ):
            continue
        normalized_name = re.sub(r"[^a-z0-9]+", "", name.lower())
        if any(alias in normalized_name for alias in normalized_aliases):
            return idx
    return None


def first_dapi_channel(prefer_last=True):
    nuclear_aliases = (
        "dapi", "hoechst", "dna", "histone", "draq",
        "ir191", "ir193", "nuclear",
    )
    nuclear = [
        idx for idx, name in enumerate(CHANNELS)
        if not any(
            token in name.lower()
            for token in ("background", "failed", "blank", "empty")
        )
        and any(
            alias in re.sub(r"[^a-z0-9]+", "", name.lower())
            for alias in nuclear_aliases
        )
    ]
    if not nuclear:
        return 0
    return nuclear[-1] if prefer_last else nuclear[0]


def configure_segmentation_channels():
    """
    Fill Mesmer channels from the channel table when shell configuration has
    not already resolved them.
    """

    if not CHANNELS:
        return

    current_nuc = os.environ.get("NUCLEAR_CHANNEL", "").strip()
    current_mem = os.environ.get("MEMBRANE_CHANNEL", "").strip()

    if not current_nuc:
        os.environ["NUCLEAR_CHANNEL"] = str(first_dapi_channel(prefer_last=True))

    if not current_mem:
        fallback_mem = first_marker_alias(
            "CellMask",
            "WGA",
            "Pan-Membrane",
            "Membrane",
            "E-Cadherin",
            "CDH1",
            "PanCK",
            "Pan-Cytokeratin",
            "Cytokeratin",
            "CD45",
            "PTPRC",
            "N-Cadherin",
            "CDH2",
            "Vimentin",
            "aSMA",
            "ACTA2",
        )
        os.environ["MEMBRANE_CHANNEL"] = str(
            fallback_mem if fallback_mem is not None else 1
        )

    os.environ["NUCLEAR_CHANNEL_NAME"] = (
        channel_name_at(os.environ.get("NUCLEAR_CHANNEL", "0")) or "unknown"
    )
    os.environ["MEMBRANE_CHANNEL_NAME"] = (
        channel_name_at(os.environ.get("MEMBRANE_CHANNEL", "1")) or "unknown"
    )


configure_segmentation_channels()


###############################################################################
# Sample and raw-file discovery
###############################################################################

RAW_EXTENSIONS = split_env_list(env_str("RAW_EXTENSIONS", ".rcpnl"))
if not RAW_EXTENSIONS:
    RAW_EXTENSIONS = [".rcpnl"]


def is_raw_file(path):
    return path.is_file() and path.suffix.lower() in {
        ext.lower() for ext in RAW_EXTENSIONS
    }


def raw_files_for_sample(sample):
    sample_dir = RAW_DIR / sample

    if not sample_dir.exists():
        return []

    return sorted(p for p in sample_dir.iterdir() if is_raw_file(p))


def stitched_image_path(sample):
    return STITCHED_DIR / sample / f"{sample}.ome.tif"


def detect_samples():
    explicit = split_env_list(
        os.environ.get("PIPELINE_SAMPLES", "")
        or os.environ.get("SAMPLES", "")
    )

    if explicit:
        return explicit

    samples = []

    # Prefer stitched images, because selected segmentation can run without raw.
    if STITCHED_DIR.exists():
        for d in sorted(STITCHED_DIR.iterdir()):
            if d.is_dir() and (d / f"{d.name}.ome.tif").exists():
                samples.append(d.name)

    if samples:
        return samples

    if RAW_DIR.exists():
        for d in sorted(RAW_DIR.iterdir()):
            if d.is_dir() and raw_files_for_sample(d.name):
                samples.append(d.name)

    return samples


SAMPLES = detect_samples()

if not SAMPLES:
    print(
        "[pipeline warning] No samples detected yet. Expected either:\n"
        f"  {STITCHED_DIR}/<sample>/<sample>.ome.tif\n"
        f"or:\n"
        f"  {RAW_DIR}/<sample>/*.rcpnl"
    )

print(f"[pipeline] Samples detected: {len(SAMPLES)}")
if SAMPLES:
    print("[pipeline] Samples: " + ", ".join(SAMPLES))

os.environ["PIPELINE_SAMPLES"] = " ".join(SAMPLES)


def raw_exp_name(path):
    return Path(path).stem


RAW_FILE_BY_SAMPLE_EXP = {}

for sample in SAMPLES:
    for raw_file in raw_files_for_sample(sample):
        RAW_FILE_BY_SAMPLE_EXP[(sample, raw_exp_name(raw_file))] = raw_file


def raw_input_for_exp(wc):
    key = (wc.sample, wc.exp)

    if key in RAW_FILE_BY_SAMPLE_EXP:
        return str(RAW_FILE_BY_SAMPLE_EXP[key])

    # Fallback for predictable names.
    for ext in RAW_EXTENSIONS:
        candidate = RAW_DIR / wc.sample / f"{wc.exp}{ext}"
        if candidate.exists():
            return str(candidate)

    # Return the canonical candidate so Snakemake reports a clear missing input.
    return str(RAW_DIR / wc.sample / f"{wc.exp}{RAW_EXTENSIONS[0]}")


def raw_inputs_for_wc(wc):
    return [str(p) for p in raw_files_for_sample(wc.sample)]


def raw_exps_for_sample(sample):
    return [raw_exp_name(p) for p in raw_files_for_sample(sample)]


def illum_outputs_for_sample(sample):
    outputs = []

    if not RUN_ILLUMINATION:
        return outputs

    for exp in raw_exps_for_sample(sample):
        outputs.append(str(ILLUM_DIR / sample / f"{exp}-ffp.tif"))
        outputs.append(str(ILLUM_DIR / sample / f"{exp}-dfp.tif"))

    return outputs


def illum_outputs_for_wc(wc):
    return illum_outputs_for_sample(wc.sample)


###############################################################################
# Resource helpers used by rules/*.smk
###############################################################################

def file_size_gib(path):
    path = Path(str(path))

    if not path.exists():
        return 0.0

    if path.is_file():
        return path.stat().st_size / (1024 ** 3)

    total = 0

    for p in path.rglob("*"):
        if p.is_file():
            try:
                total += p.stat().st_size
            except OSError:
                pass

    return total / (1024 ** 3)


def sample_raw_size_gib(sample):
    return sum(file_size_gib(p) for p in raw_files_for_sample(sample))


def effective_stitch_size_gib(sample):
    stitched = stitched_image_path(sample)

    if stitched.exists():
        return file_size_gib(stitched)

    return sample_raw_size_gib(sample)


def segmentation_plane_size_gib(stitched_gib):
    """Estimate one full-resolution channel from a multichannel OME-TIFF."""
    channel_count = max(env_int("CHANNEL_COUNT", 0), 0)
    if channel_count > 0:
        return max(float(stitched_gib) / channel_count, 0.0)

    # Missing channel metadata is unusual because segmentation channel
    # validation uses the same CSV. Retain a conservative fallback.
    return max(float(stitched_gib), 0.0)


def round_mem_mb(value, quantum=8000):
    return int(math.ceil(float(value) / quantum) * quantum)


def auto_mem_mb(gib, stage, attempt=1):
    """
    Conservative resource heuristic.
    Environment overrides are respected when present.
    """

    stage = str(stage).lower()
    attempt = max(int(attempt), 1)
    gib = max(float(gib), 0.0)

    override_by_stage = {
        "illum": "ILLUMINATION_MEM_MB",
        "stitch": "STITCHING_MEM_MB",
        "mesmer": "MESMER_MEM_MB",
        "stardist": "STARDIST_MEM_MB",
        "quant": "QUANTIFICATION_MEM_MB",
        "filter": "FILTER_MEM_MB",
    }

    override = os.environ.get(override_by_stage.get(stage, ""), "").strip()
    if override:
        return int(override) * attempt

    if stage == "mesmer":
        # The worker reads two channels, not the complete multichannel file.
        # This estimate includes preprocessing copies, both tiled label sets,
        # and DeepTile's full-resolution stitching workspace.
        plane_gib = segmentation_plane_size_gib(gib)
        base = round_mem_mb(40000 + plane_gib * 12000)
        base = min(max(base, 64000), 240000)
        return min(base * attempt, 480000)

    if stage == "stardist":
        # StarDist reads one nuclear channel and holds a normalized float32
        # image plus labels and sparse object candidates.
        plane_gib = segmentation_plane_size_gib(gib)
        base = round_mem_mb(32000 + plane_gib * 8000)
        base = min(max(base, 64000), 160000)
        return min(base * attempt, 320000)

    if stage == "quant":
        base = 64000 + int(gib * 5000)
        return min(max(base, 64000) * attempt, 320000)

    if stage == "filter":
        base = 32000 + int(gib * 4000)
        return min(max(base, 32000) * attempt, 240000)

    if stage == "stitch":
        base = 64000 + int(gib * 8000)
        return min(max(base, 64000) * attempt, 512000)

    if stage == "illum":
        base = 64000 + int(gib * 8000)
        return min(max(base, 64000) * attempt, 512000)

    return max(16000, int(16000 + gib * 2000)) * attempt


def auto_runtime(gib, stage, attempt=1):
    """
    Runtime in minutes.
    """

    stage = str(stage).lower()
    attempt = max(int(attempt), 1)
    gib = max(float(gib), 0.0)

    override_by_stage = {
        "illum": "ILLUMINATION_RUNTIME_MIN",
        "stitch": "STITCHING_RUNTIME_MIN",
        "mesmer": "MESMER_RUNTIME_MIN",
        "stardist": "STARDIST_RUNTIME_MIN",
        "quant": "QUANTIFICATION_RUNTIME_MIN",
        "filter": "FILTER_RUNTIME_MIN",
    }

    override = os.environ.get(override_by_stage.get(stage, ""), "").strip()
    if override:
        return int(override) * attempt

    if stage == "mesmer":
        return min(max(360, int(240 + gib * 2.4)) * attempt, 1440)

    if stage == "stardist":
        return min(max(300, int(180 + gib * 2.1)) * attempt, 1200)

    if stage == "quant":
        return min(max(240, int(120 + gib * 8)) * attempt, 960)

    if stage == "filter":
        return min(max(180, int(90 + gib * 8)) * attempt, 720)

    if stage == "stitch":
        return min(max(240, int(120 + gib * 12)) * attempt, 1440)

    if stage == "illum":
        return min(max(240, int(120 + gib * 12)) * attempt, 1440)

    return 120 * attempt


###############################################################################
# Output path helpers used by rules/*.smk
###############################################################################

def segmentation_mask(method, sample, compartment="nuclear"):
    method = str(method)
    sample = str(sample)

    comp = "nuclear" if compartment is None else str(compartment)
    comp = comp.replace("_", "-").lower()

    if method == "stardist":
        return str(SEGMENTED_DIR / "stardist" / f"{sample}_mask_nuclear.tif")

    if method == "mesmer":
        if comp in {"nuclear", "nuc"}:
            return str(SEGMENTED_DIR / "mesmer" / f"{sample}_mask_nuclear.tif")

        if comp in {"whole-cell", "wholecell", "whole"}:
            return str(SEGMENTED_DIR / "mesmer" / f"{sample}_mask_whole_cell.tif")

    raise ValueError(
        f"Unsupported segmentation mask request: method={method}, "
        f"sample={sample}, compartment={compartment}"
    )


def quant_csv(method, sample, compartment="nuclear"):
    method = str(method)
    sample = str(sample)

    comp = "nuclear" if compartment is None else str(compartment)
    comp = comp.replace("_", "-").lower()

    if comp in {"nuclear", "nuc"}:
        return str(QUANT_DIR / method / f"{sample}_nuclear.csv")

    if comp in {"whole-cell", "wholecell", "whole"}:
        return str(QUANT_DIR / method / f"{sample}_whole_cell.csv")

    raise ValueError(
        f"Unsupported quantification CSV request: method={method}, "
        f"sample={sample}, compartment={compartment}"
    )


def filtered_tif_path(method, sample, marker):
    return str(
        FILTERED_TIF_DIR
        / str(method)
        / str(marker)
        / f"{sample}.ome_{marker}_tophat.tif"
    )


def filtered_csv_path(method, sample, compartment="nuclear"):
    method = str(method)
    sample = str(sample)

    comp = "nuclear" if compartment is None else str(compartment)
    comp = comp.replace("_", "-").lower()

    if comp in {"nuclear", "nuc"}:
        return str(FILTERED_CSV_DIR / method / f"{sample}_filtered.csv")

    if comp in {"whole-cell", "wholecell", "whole"}:
        return str(FILTERED_CSV_DIR / method / f"{sample}_whole_cell_filtered.csv")

    raise ValueError(
        f"Unsupported filtered CSV request: method={method}, "
        f"sample={sample}, compartment={compartment}"
    )


###############################################################################
# Target helpers
###############################################################################

def stitched_targets():
    return [str(stitched_image_path(sample)) for sample in SAMPLES]


def illumination_targets():
    targets = []
    for sample in SAMPLES:
        targets.extend(illum_outputs_for_sample(sample))
    return targets


def mesmer_mask_targets():
    targets = []

    for sample in SAMPLES:
        if MESMER_COMPARTMENT in {"nuclear", "both"}:
            targets.append(segmentation_mask("mesmer", sample, "nuclear"))

        if MESMER_COMPARTMENT in {"whole-cell", "both"}:
            targets.append(segmentation_mask("mesmer", sample, "whole-cell"))

    return targets


def stardist_mask_targets():
    return [segmentation_mask("stardist", sample, "nuclear") for sample in SAMPLES]


def segmentation_targets_for_method(method):
    if method == "mesmer":
        return mesmer_mask_targets()

    if method == "stardist":
        return stardist_mask_targets()

    raise ValueError(f"Unknown segmentation method: {method}")


def selected_segmentation_targets():
    targets = []

    for method in SELECTED_SEGMENTATION_METHODS:
        targets.extend(segmentation_targets_for_method(method))

    return targets


def quantification_targets_for_method(method):
    targets = []

    if method == "mesmer":
        if MESMER_COMPARTMENT in {"nuclear", "both"}:
            targets.extend(quant_csv("mesmer", sample, "nuclear") for sample in SAMPLES)

        if MESMER_COMPARTMENT in {"whole-cell", "both"}:
            targets.extend(quant_csv("mesmer", sample, "whole-cell") for sample in SAMPLES)

    elif method == "stardist":
        targets.extend(quant_csv("stardist", sample, "nuclear") for sample in SAMPLES)

    else:
        raise ValueError(f"Unknown quantification method: {method}")

    return list(targets)


def selected_quantification_targets():
    targets = []

    for method in SELECTED_SEGMENTATION_METHODS:
        targets.extend(quantification_targets_for_method(method))

    return targets


def ensure_filtering_configured():
    if MARKER_CHANNEL_MAP:
        return True

    msg = (
        "Filtering is required, but biological marker map is empty. "
        f"Expected: {CHANNELS_QUANTIFICATION_CSV}"
    )

    if PIPELINE_RELAX_CONFIG_VALIDATION:
        print(f"[pipeline warning] {msg}")
        return False

    raise ValueError(msg)


def filtering_targets_for_method(method):
    if not SAMPLES:
        return []

    ensure_filtering_configured()

    targets = []

    if method == "mesmer":
        if MESMER_COMPARTMENT in {"nuclear", "both"}:
            targets.extend(filtered_csv_path("mesmer", sample, "nuclear") for sample in SAMPLES)

        if MESMER_COMPARTMENT in {"whole-cell", "both"}:
            targets.extend(filtered_csv_path("mesmer", sample, "whole-cell") for sample in SAMPLES)

    elif method == "stardist":
        targets.extend(filtered_csv_path("stardist", sample, "nuclear") for sample in SAMPLES)

    else:
        raise ValueError(f"Unknown filtering method: {method}")

    return list(targets)


def selected_filtering_targets():
    targets = []

    for method in SELECTED_SEGMENTATION_METHODS:
        targets.extend(filtering_targets_for_method(method))

    return targets


###############################################################################
# State flags
###############################################################################

ILLUMINATION_COMPLETE_FLAG = str(STATE_DIR / "illumination_complete.flag")
STITCHING_COMPLETE_FLAG = str(STATE_DIR / "stitching_complete.flag")

SEGMENTATION_MESMER_COMPLETE_FLAG = str(STATE_DIR / "segmentation_mesmer_complete.flag")
SEGMENTATION_STARDIST_COMPLETE_FLAG = str(STATE_DIR / "segmentation_stardist_complete.flag")
SEGMENTATION_COMPLETE_FLAG = str(STATE_DIR / "segmentation_complete.flag")
SEGMENTATION_METHOD_FILE = str(STATE_DIR / "segmentation_method.txt")

QUANTIFICATION_MESMER_COMPLETE_FLAG = str(STATE_DIR / "quantification_mesmer_complete.flag")
QUANTIFICATION_STARDIST_COMPLETE_FLAG = str(STATE_DIR / "quantification_stardist_complete.flag")
QUANTIFICATION_COMPLETE_FLAG = str(STATE_DIR / "quantification_complete.flag")

FILTERING_MESMER_COMPLETE_FLAG = str(STATE_DIR / "filtering_mesmer_complete.flag")
FILTERING_STARDIST_COMPLETE_FLAG = str(STATE_DIR / "filtering_stardist_complete.flag")
FILTERING_COMPLETE_FLAG = str(STATE_DIR / "filtering_complete.flag")

PIPELINE_COMPLETE_FLAG = str(STATE_DIR / "pipeline_complete.flag")


def selected_segmentation_stage_flags(wildcards=None):
    flags = []

    if "mesmer" in SELECTED_SEGMENTATION_METHODS:
        flags.append(SEGMENTATION_MESMER_COMPLETE_FLAG)

    if "stardist" in SELECTED_SEGMENTATION_METHODS:
        flags.append(SEGMENTATION_STARDIST_COMPLETE_FLAG)

    return flags


def selected_quantification_stage_flags(wildcards=None):
    flags = []

    if "mesmer" in SELECTED_SEGMENTATION_METHODS:
        flags.append(QUANTIFICATION_MESMER_COMPLETE_FLAG)

    if "stardist" in SELECTED_SEGMENTATION_METHODS:
        flags.append(QUANTIFICATION_STARDIST_COMPLETE_FLAG)

    return flags


def selected_filtering_stage_flags(wildcards=None):
    flags = []

    if "mesmer" in SELECTED_SEGMENTATION_METHODS:
        flags.append(FILTERING_MESMER_COMPLETE_FLAG)

    if "stardist" in SELECTED_SEGMENTATION_METHODS:
        flags.append(FILTERING_STARDIST_COMPLETE_FLAG)

    return flags


###############################################################################
# Default target
###############################################################################

def final_targets(wildcards=None):
    """
    Default behavior for plain `snakemake`.

    run_pipeline.sh normally calls explicit stage targets such as:
      stage_segmentation_mesmer
      stage_quantification_mesmer
      stage_filtering_mesmer
    """

    if RUN_FILTERING:
        return [FILTERING_COMPLETE_FLAG]

    if RUN_QUANTIFICATION:
        return [QUANTIFICATION_COMPLETE_FLAG]

    if RUN_SEGMENTATION:
        return [SEGMENTATION_COMPLETE_FLAG]

    if RUN_STITCHING:
        return [STITCHING_COMPLETE_FLAG]

    if RUN_ILLUMINATION:
        return [ILLUMINATION_COMPLETE_FLAG]

    return [PIPELINE_COMPLETE_FLAG]


rule all:
    input:
        final_targets


###############################################################################
# Include real modular rules
###############################################################################

include: "rules/illumination.smk"
include: "rules/stitching.smk"
include: "rules/mesmer.smk"
include: "rules/stardist.smk"
include: "rules/quantification.smk"
include: "rules/filtering.smk"


###############################################################################
# Stage aggregate rules called by run_pipeline.sh
###############################################################################

rule stage_illumination:
    input:
        lambda wc: illumination_targets()
    output:
        ILLUMINATION_COMPLETE_FLAG
    run:
        touch_file(output[0])


rule stage_stitching:
    input:
        lambda wc: stitched_targets()
    output:
        STITCHING_COMPLETE_FLAG
    run:
        touch_file(output[0])


rule stage_segmentation_mesmer:
    input:
        lambda wc: [STITCHING_COMPLETE_FLAG] + segmentation_targets_for_method("mesmer")
    output:
        SEGMENTATION_MESMER_COMPLETE_FLAG
    run:
        touch_file(output[0])


rule stage_segmentation_stardist:
    input:
        lambda wc: [STITCHING_COMPLETE_FLAG] + segmentation_targets_for_method("stardist")
    output:
        SEGMENTATION_STARDIST_COMPLETE_FLAG
    run:
        touch_file(output[0])


rule stage_segmentation_complete:
    input:
        selected_segmentation_stage_flags
    output:
        flag=SEGMENTATION_COMPLETE_FLAG,
        method_file=SEGMENTATION_METHOD_FILE
    run:
        touch_file(output.flag)
        write_text(output.method_file, SEGMENTATION_METHOD + "\n")


rule stage_quantification_mesmer:
    input:
        lambda wc: [SEGMENTATION_MESMER_COMPLETE_FLAG] + quantification_targets_for_method("mesmer")
    output:
        QUANTIFICATION_MESMER_COMPLETE_FLAG
    run:
        touch_file(output[0])


rule stage_quantification_stardist:
    input:
        lambda wc: [SEGMENTATION_STARDIST_COMPLETE_FLAG] + quantification_targets_for_method("stardist")
    output:
        QUANTIFICATION_STARDIST_COMPLETE_FLAG
    run:
        touch_file(output[0])


rule stage_quantification_complete:
    input:
        selected_quantification_stage_flags
    output:
        QUANTIFICATION_COMPLETE_FLAG
    run:
        touch_file(output[0])


rule stage_filtering_mesmer:
    input:
        lambda wc: [QUANTIFICATION_MESMER_COMPLETE_FLAG] + filtering_targets_for_method("mesmer")
    output:
        FILTERING_MESMER_COMPLETE_FLAG
    run:
        touch_file(output[0])


rule stage_filtering_stardist:
    input:
        lambda wc: [QUANTIFICATION_STARDIST_COMPLETE_FLAG] + filtering_targets_for_method("stardist")
    output:
        FILTERING_STARDIST_COMPLETE_FLAG
    run:
        touch_file(output[0])


rule stage_filtering_complete:
    input:
        selected_filtering_stage_flags
    output:
        FILTERING_COMPLETE_FLAG
    run:
        touch_file(output[0])


rule stage_pipeline_complete:
    input:
        FILTERING_COMPLETE_FLAG
    output:
        PIPELINE_COMPLETE_FLAG
    run:
        touch_file(output[0])


###############################################################################
# Diagnostics
###############################################################################

rule print_pipeline_config:
    output:
        str(STATE_DIR / "printed_config.flag")
    run:
        print("")
        print("========== PIPELINE CONFIG ==========")
        print(f"PROJECT_ID                 : {PROJECT_ID}")
        print(f"PROJECT_ROOT               : {PROJECT_ROOT}")
        print(f"DATASET_OWNER              : {DATASET_OWNER}")
        print(f"DATASET_NAME               : {DATASET_NAME}")
        print(f"BASE                       : {BASE}")
        print(f"SCRIPTS_DIR                : {SCRIPTS_DIR}")
        print(f"DATA_DIR                   : {DATA_DIR}")
        print(f"RAW_DIR                    : {RAW_DIR}")
        print(f"ILLUM_DIR                  : {ILLUM_DIR}")
        print(f"STITCHED_DIR               : {STITCHED_DIR}")
        print(f"SEGMENTED_DIR              : {SEGMENTED_DIR}")
        print(f"QUANT_DIR                  : {QUANT_DIR}")
        print(f"FILTERED_TIF_DIR           : {FILTERED_TIF_DIR}")
        print(f"FILTERED_CSV_DIR           : {FILTERED_CSV_DIR}")
        print(f"STATE_DIR                  : {STATE_DIR}")
        print(f"LOG_ROOT                   : {LOG_ROOT}")
        print(f"CHANNELS_QUANTIFICATION_CSV: {CHANNELS_QUANTIFICATION_CSV}")
        print(f"CHANNELS                   : {len(CHANNELS)}")
        print(f"BIOLOGICAL_MARKERS         : {len(BIOLOGICAL_MARKERS)}")
        print(f"SEGMENTATION_METHOD        : {SEGMENTATION_METHOD}")
        print(f"MESMER_COMPARTMENT         : {MESMER_COMPARTMENT}")
        print(f"NUCLEAR_CHANNEL            : {os.environ.get('NUCLEAR_CHANNEL', '')} "
              f"({channel_name_at(os.environ.get('NUCLEAR_CHANNEL', '0'))!r})")
        print(f"MEMBRANE_CHANNEL           : {os.environ.get('MEMBRANE_CHANNEL', '')} "
              f"({channel_name_at(os.environ.get('MEMBRANE_CHANNEL', '0'))!r})")
        print(f"SAMPLES                    : {len(SAMPLES)}")
        print(", ".join(SAMPLES))
        print("")
        print("MARKER_CHANNEL_MAP:")
        print(json.dumps(MARKER_CHANNEL_MAP, indent=2, ensure_ascii=False))
        print("=====================================")
        print("")
        touch_file(output[0])


