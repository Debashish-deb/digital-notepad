# Research Knowledge Base
RESEARCH_KB_QDRANT_COLLECTION=research_knowledge
RESEARCH_KB_QDRANT_VECTOR_NAME=text
RESEARCH_KB_VECTOR_SIZE=384
RESEARCH_KB_EMBEDDING_PROVIDER=local
RESEARCH_KB_EMBEDDING_MODEL=hashing-fallback
RESEARCH_KB_RERANK_PROVIDER=none
RESEARCH_KB_CRAWL_DELAY_SECONDS=1.0
RESEARCH_KB_MAX_PUBLIC_PAGES=300
RESEARCH_KB_ENABLE_PLAYWRIGHT=false
RESEARCH_KB_ENABLE_PUBMED=true
RESEARCH_KB_ENABLE_CROSSREF=true
RESEARCH_KB_ENABLE_OPENALEX=false
RESEARCH_KB_ENABLE_SEMANTIC_SCHOLAR=false
RESEARCH_KB_COPYRIGHT_MODE=metadata_first

# Copilot rate limiting and retrieval cache
COPILOT_RATE_LIMIT_PER_MINUTE=30
COPILOT_RATE_LIMIT_WINDOW_SEC=60
RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_CACHE_TTL_SEC=120
RETRIEVAL_CACHE_MAX_ENTRIES=256

# Persistent agent audit logging (requires sql/143_agent_audit_log.sql migration)
AGENT_AUDIT_PERSIST_ENABLED=false
