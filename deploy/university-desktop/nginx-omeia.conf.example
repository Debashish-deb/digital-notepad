# Nginx TLS reverse proxy to uvicorn on 127.0.0.1:8000
# Replace api.example.fi and certificate paths before enabling.

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api.example.fi;

    ssl_certificate     /etc/letsencrypt/live/api.example.fi/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.example.fi/privkey.pem;

    client_max_body_size 64m;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }
}

server {
    listen 80;
    listen [::]:80;
    server_name api.example.fi;
    return 301 https://$host$request_uri;
}
