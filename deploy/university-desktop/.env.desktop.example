# University desktop backend — copy to:
#   Linux prod: /opt/omeia/deploy/university-desktop/.env
#   Mac dev:    configs/.env  (or deploy/university-desktop/.env)
# NEVER commit real secrets. NEVER put these in Hostinger / Vite (no VITE_* here).

APP_ENV=production
LOG_LEVEL=INFO

# Hostinger React + local Vite (comma-separated origins)
# Mac dev example:
CORS_ORIGINS=http://localhost:5173,https://app.yourdomain.example
# Linux prod: use Hostinger HTTPS only, e.g. CORS_ORIGINS=https://app.yourdomain.example

# --- Auth ---
# Mac local dev default: skip Firebase verify on API (still use Firebase in React if needed)
PLATFORM_AUTH_DISABLED=true
# Linux production:
# PLATFORM_AUTH_DISABLED=false

FIREBASE_PROJECT_ID=farkki-digital-notebook
FIREBASE_AUTH_DOMAIN=farkki-digital-notebook.firebaseapp.com
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_APP_ID=1:570069536455:web:4c4623a81262e6c4eef8e2
# Linux: /opt/omeia/secrets/firebase-adminsdk.json
# macOS: ~/secrets/firebase-adminsdk.json or path under repo
FIREBASE_SERVICE_ACCOUNT_PATH=/opt/omeia/secrets/firebase-adminsdk.json
PLATFORM_ADMIN_EMAILS=anniina.farkkila@helsinki.fi,debashish.deb@helsinki.fi,joonas.jukonen@helsinki.fi

# --- Supabase (metadata / vectors — backend only) ---
SUPABASE_URL=https://ccpvupyiqxubcupvtrtp.supabase.co
SUPABASE_PROJECT_REF=ccpvupyiqxubcupvtrtp
SUPABASE_POOLER_HOST=aws-1-eu-central-1.pooler.supabase.com
SUPABASE_POOLER_PORT=6543
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

SUPABASE_SYNC_ENABLED=false
SUPABASE_MAX_TEXT_BYTES=50000
SUPABASE_SYNC_BATCH_SIZE=100
SUPABASE_SKIP_IMAGE_SYNC=true
SUPABASE_MAX_DB_MB=450

# --- DataCloud WebDAV (primary storage — never expose to React) ---
DATACLOUD_WEBDAV_BASE_URL=https://datacloud.helsinki.fi/remote.php/dav/files/<user>%40helsinki.fi
DATACLOUD_ROOT=/farkkila/LAB-ASSISTANT-PLATFORM
DATACLOUD_USERNAME=
DATACLOUD_APP_PASSWORD=

# --- P-drive (secondary — mounted filesystem) ---
PDRIVE_ENABLED=false

# Linux SMB/GVFS example
# LAB_STORAGE_ROOT=/run/user/1000/gvfs/smb-share:server=...
PDRIVE_MOUNT_PATH=/mnt/pdrive

# macOS examples (uncomment and adjust volume names)
# LAB_STORAGE_ROOT=/Volumes/farkki_digital_notebook
# PDRIVE_MOUNT_PATH=/Volumes/Pdrive

PDRIVE_LOGICAL_ROOT=pdrive://

# --- Local lab paths (digitalization / previews) ---
LAB_STORAGE_ROOT=/mnt/lab-projects
DATABASE_ROOT=

# Autonomous processor (OS daemon — independent of Cursor IDE)
# docs/28_AUTONOMOUS_PROCESSOR.md
PROCESSOR_AUTONOMOUS=true
PROCESSOR_INTERVAL_SEC=3600
PROCESSOR_STEPS=vault,digitalize,supabase_sync
PROJECTS_ROOT=
OMEIA_REPO_ROOT=/opt/omeia/digital-notepad

# Preview cache: local dir or under LAB_STORAGE_ROOT/12_APP_PREVIEWS
PREVIEW_CACHE_DIR=
THUMBNAIL_MAX_PER_RUN=25
THUMBNAIL_SKIP_IMAGE_BYTES=52428800

# --- Optional local Postgres fallback (if Supabase password unset) ---
POSTGRES_CONN=

# --- Scheduled ingest ---
INGEST_SCHEDULE_MAX_ENTRIES=500

# --- AI (optional; Groq or local later) ---
# GROQ_API_KEY=

# --- Guardrails ---
ALLOW_PATIENT_DATA=false
DEFAULT_SENSITIVITY_MODE=documentation_only
