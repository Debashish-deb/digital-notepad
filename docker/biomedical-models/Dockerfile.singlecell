FROM pytorch/pytorch:2.2.2-cuda12.1-cudnn8-runtime

ENV PYTHONUNBUFFERED=1
ENV HF_HOME=/models/hf-cache
ENV BIOMODEL_LAZY_LOAD=true

WORKDIR /app
COPY docker/biomedical-models/requirements-gpu.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

COPY docker/biomedical-models/shared /app/shared
COPY docker/biomedical-models/singlecell_base/main.py /app/main.py

EXPOSE 8100
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8100"]
