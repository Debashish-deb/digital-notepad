# Ollama reverse proxy — bearer-token gated when OLLAMA_INTERNAL_TOKEN is set.
{
	admin off
}

:11434 {
	@has_token expression {env.OLLAMA_INTERNAL_TOKEN} != ""

	handle @has_token {
		@authorized header Authorization "Bearer {env.OLLAMA_INTERNAL_TOKEN}"
		handle @authorized {
			reverse_proxy ollama:11434 {
				header_up -Authorization
			}
		}
		respond "Unauthorized" 401
	}

	handle {
		reverse_proxy ollama:11434
	}
}
