# =============================================================================
# OMEIA Linux workstation — canonical production/dev host (copy → configs/.env)
# Mac clients: open http://<tailscale-ip>:5173 (no local API/Docker required)
#
# After git pull on Linux:
#   ./scripts/ops/linux_post_pull.sh
#   ./scripts/start_linux.sh                           # or start_linux_desktop.sh
# =============================================================================

OMEIA_DEPLOYMENT_PROFILE=linux_desktop
DOCKER_LOCAL=true
DOCKER_AUTO_START=true

# Frontend: dev (Vite :5173) | prod (built dist on API :8000)
OMEIA_FRONTEND_MODE=dev
OMEIA_SERVE_FRONTEND_STATIC=true
ENABLE_REQUEST_METRICS=true
ENABLE_OBSERVABILITY=true
APP_ENV=development

# Startup: launcher sets DOCKER_COMPOSE_STARTED=true after docker compose up.
# API skips redundant lifespan bootstrap when that flag is set.
DOCKER_LIFESPAN_BOOTSTRAP=auto
POSTGRES_POOL_ENABLED=true
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=10
READINESS_REQUIRE_QDRANT=false
READINESS_REQUIRE_LLM=false

# --- Data roots (set OMEIA_DATA_ROOT once; paths derive from it) ---
# OMEIA_DATA_ROOT=/var/lib/omeia
OMEIA_DATA_ROOT=/var/lib/omeia
DATABASE_ROOT=${OMEIA_DATA_ROOT}/database
PROJECTS_ROOT=${OMEIA_DATA_ROOT}/database/projects
# LAB_STORAGE_ROOT=/mnt/lab-notebook

POSTGRES_CONN=postgresql://farkki:farkki_dev_password@127.0.0.1:5432/farkki_ai
QDRANT_URL=http://127.0.0.1:6333

# --- LLM + embeddings (Docker Ollama) ---
LLM_PROVIDER=ollama
CHAT_LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_INTERNAL_TOKEN=
EMBEDDING_PROVIDER=ollama
TEXT_EMBEDDING_MODEL=nomic-embed-text
TEXT_EMBEDDING_DIM=768
RESEARCH_KB_VECTOR_SIZE=768

# --- Knowledge platform (remediation Phase 1) ---
KNOWLEDGE_INDEXER_ENABLED=true
CANONICAL_CHUNK_PIPELINE=false
PROJECT_RBAC_ENABLED=false
PLATFORM_CHUNK_WRITE=true
VAULT_JSON_FALLBACK=true
# Production: set true so /database-static and /projects-static require Firebase.
REQUIRE_AUTH_STATIC=false
VAULT_USE_VECTOR_INDEXER=false
VECTORIZATION_ENABLED=true
ENABLE_OCR=false
OCR_ENGINE=tesseract

# --- Phase 10 — Research Strategy Assistant (enable after validation) ---
OMEIA_RESEARCH_STRATEGY_ASSISTANT=false
OMEIA_STRATEGY_REPORT_MODE=true
OMEIA_STRATEGY_EXTERNAL_SEARCH=false
OMEIA_STRATEGY_REQUIRE_CITATIONS=true

# --- Phase 11 — Continuous quality evaluation ---
OMEIA_CONTINUOUS_EVAL_ENABLED=true
OMEIA_QUALITY_GATE_STRICT=false

# --- Biomedical models (same host) ---
BIOMEDICAL_MODELS_GATEWAY_URL=http://127.0.0.1:8100
BIOMEDICAL_EMBEDDINGS_URL=http://127.0.0.1:8101
BIOMEDICAL_BIOGPT_URL=http://127.0.0.1:8102
BIOMEDICAL_TXGEMMA_URL=http://127.0.0.1:8103
BIOMEDICAL_GENEFORMER_URL=http://127.0.0.1:8110
BIOMEDICAL_SCGPT_URL=http://127.0.0.1:8111
BIOMEDICAL_SCPRINT_URL=http://127.0.0.1:8112
BIOMODEL_LAZY_LOAD=true

# --- Auth (set per lab policy) ---
PLATFORM_AUTH_DISABLED=false
# Copy Firebase/Supabase keys from Mac configs/.env manually — never commit secrets.
