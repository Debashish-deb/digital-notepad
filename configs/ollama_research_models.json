    "llama3.2:3b",
    "phi3:mini",
    "medgemma:4b",
    "meditron:7b",
    "medllama2:7b",
    "qwen2.5:7b-instruct",
    "llama3.1:8b",
    "mistral-nemo:12b"
  ],
  "models": [
    {
      "tag": "qwen2.5:3b",
      "size_tier": "small",
      "use_case": "fast_eval",
      "omeia_chat": true,
      "omeia_batch_eval": true,
      "notes": "Default OLLAMA_MODEL \u2014 daily dev, smoke tests, low-latency lab assistant."
