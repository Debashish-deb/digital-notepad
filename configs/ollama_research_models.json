    {
      "tag": "phi3:mini",
      "size_tier": "small",
      "use_case": "fast_eval",
      "omeia_chat": true,
      "omeia_batch_eval": true,
      "notes": "Fastest local summarization and eval iterations."
    },
    {
      "tag": "medgemma:4b",
      "size_tier": "small",
      "use_case": "medical_general",
      "omeia_chat": true,
      "omeia_batch_eval": false,
