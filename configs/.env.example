# OMEIA Lab Assistant Platform — copy to .env (never commit real .env)
# Dev runs on local Postgres + Qdrant. Production: fill Firebase, Supabase, DataCloud when ready.
# Deploy topology: docs/26_PRODUCTION_DEPLOYMENT.md | checklist: configs/DEPLOYMENT_ENV.md

APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=*

# --- Linux workstation deployment ---
# dev = Vite :5173 + API :8000 (default)
# prod = npm run build + serve dist from FastAPI :8000 (or Caddy platform profile on :5173)
OMEIA_FRONTEND_MODE=dev
OMEIA_SERVE_FRONTEND_STATIC=true
ENABLE_REQUEST_METRICS=false
ENABLE_OBSERVABILITY=true

# --- Startup / readiness (audit hardening) ---
# start.sh waits on GET /ready (Postgres required). /live is process-only liveness.
# DOCKER_COMPOSE_STARTED=true is set by scripts/dev/start_linux_desktop.sh after compose up.
DOCKER_LIFESPAN_BOOTSTRAP=auto
POSTGRES_POOL_ENABLED=true
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=10
READINESS_REQUIRE_QDRANT=false
READINESS_REQUIRE_LLM=false

# =============================================================================
# PRODUCTION (split hosts) — do not copy this block verbatim into one file
# =============================================================================
# Hostinger (app subdomain) — set in react_frontend/.env.production BEFORE npm run build:
#   VITE_API_URL=https://api.yourdomain.example
#   VITE_FIREBASE_API_KEY=...
#   VITE_FIREBASE_AUTH_DOMAIN=farkki-digital-notebook.firebaseapp.com
#   (other VITE_FIREBASE_* — see configs/FIREBASE_WEB_SETUP.md)
#
# University desktop backend — deploy/university-desktop/.env (see install_desktop_backend.sh):
#   APP_ENV=production
#   CORS_ORIGINS=https://app.yourdomain.example
#   PLATFORM_AUTH_DISABLED=false
#   FIREBASE_SERVICE_ACCOUNT_PATH=/opt/omeia/secrets/firebase-adminsdk.json
#   SUPABASE_* and SUPABASE_DB_PASSWORD (backend only — never Vite)
#   DATACLOUD_* (backend only — never Vite)
#
# Example layout:
#   https://app.yourdomain.example  → Hostinger static dist/
#   https://api.yourdomain.example  → desktop Caddy/nginx → 127.0.0.1:8000
# =============================================================================

# --- Local dev database (default until Supabase hosted is provided) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=farkki_ai
POSTGRES_USER=farkki
POSTGRES_PASSWORD=farkki_dev_password
POSTGRES_CONN=postgresql://farkki:farkki_dev_password@localhost:5432/farkki_ai

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
DOCUMENT_QDRANT_COLLECTION=doc_chunks
DOCUMENT_QDRANT_VECTOR_NAME=text
# Phase 1 — index coherence (align all collections to same dim)
TEXT_EMBEDDING_DIM=768
RESEARCH_KB_VECTOR_SIZE=768
# Re-index after dim change:
#   PYTHONPATH=. python3 scripts/ingest/reindex_vectors.py
#   PYTHONPATH=. python3 scripts/ingest/reindex_research_vectors.py

# Phase 1 — index + auth flags (default safe / backward-compatible)
KNOWLEDGE_INDEXER_ENABLED=false
PLATFORM_CHUNK_WRITE=true
# When false, vault search uses Postgres only (no JSON inventory fallback).
# On Linux after reindex: set VECTORIZATION_ENABLED=true, then VAULT_JSON_FALLBACK=false.
VAULT_JSON_FALLBACK=true
REQUIRE_AUTH_STATIC=false
# When true, vault ingestion always uses vector_indexer when VECTORIZATION_ENABLED=true.
VAULT_USE_VECTOR_INDEXER=false

# Phase 2 — pipeline consolidation
CANONICAL_CHUNK_PIPELINE=false
TWIN_DUAL_WRITE=false
CHUNK_SIZE_TOKENS=700
CHUNK_OVERLAP_TOKENS=100

# Phase 3 — OCR workflow
ENABLE_OCR=false
OCR_ENGINE=tesseract

# Phase 4 — Firebase researcher binding + project RBAC (default off)
PROJECT_RBAC_ENABLED=false

# Phase 10 — Research Strategy Assistant (default off until Linux validation)
OMEIA_RESEARCH_STRATEGY_ASSISTANT=false
OMEIA_STRATEGY_REPORT_MODE=true
OMEIA_STRATEGY_EXTERNAL_SEARCH=false
OMEIA_STRATEGY_REQUIRE_CITATIONS=true

# Phase 11 — Continuous quality evaluation (default off; enable on Linux after migration 149)
OMEIA_CONTINUOUS_EVAL_ENABLED=false
OMEIA_QUALITY_GATE_STRICT=false

# Unified search (⌘K omnibox + copilot shared SearchService)
# Endpoints: /api/platform/unified-search, /api/platform/search-suggestions,
#            /api/platform/search-index-status, /api/project-files/search
# Apply sql/141_search_platform.sql once for platform.search_query_log

# stub = repo processed JSON + DATABASE_ROOT (portable dev, git-push safe)
# local = explicit workstation paths | remote = future SMB/DataCloud mounts
OMEIA_STORAGE_MODE=stub

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=farkki_dev_password

# --- Repo paths (local data lives OUTSIDE git — never commit database/) ---
# Leave OMEIA_REPO_ROOT empty to use this repository root.
OMEIA_REPO_ROOT=
# Sibling folder after migration (default): ../OMEIA-database
# Or set OMEIA_DATABASE_ROOT / DATABASE_ROOT to an absolute path.
DATABASE_ROOT=../OMEIA-database
PROJECTS_ROOT=

# --- Firebase Auth: Email/Password only (NO Google Sign-In) ---
# Project: Farkki-digital-notebook / farkki-digital-notebook (570069536455)
# Console owner (for Firebase/Google Cloud login only — never commit password):
# FIREBASE_CONSOLE_EMAIL=farkkilalab@gmail.com
# Lab users sign in with @helsinki.fi on the platform, not this Gmail.
# Enable Email/Password in Firebase Console → Authentication → Sign-in method.
# Disable Google and other OAuth providers.
PLATFORM_AUTH_DISABLED=true
FIREBASE_PROJECT_NAME=Farkki-digital-notebook
FIREBASE_PROJECT_ID=farkki-digital-notebook
FIREBASE_PROJECT_NUMBER=570069536455
FIREBASE_AUTH_DOMAIN=farkki-digital-notebook.firebaseapp.com
FIREBASE_STORAGE_BUCKET=farkki-digital-notebook.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=570069536455
FIREBASE_MEASUREMENT_ID=G-24JLFQYRTG
# Web app OMEIA.AI — see configs/FIREBASE_WEB_SETUP.md for full console snippet
FIREBASE_WEB_APP_NICKNAME=OMEIA.AI
FIREBASE_WEB_APP_ID=1:570069536455:web:4c4623a81262e6c4eef8e2
# Web API key — set in configs/.env only (not committed)
FIREBASE_WEB_API_KEY=
# Server: service account JSON for token verification (NOT user Google login).
# Copy to configs/secrets/firebase-adminsdk.json — never commit, never put under public/.
FIREBASE_SERVICE_ACCOUNT_PATH=
# Legacy alias (same path):
GOOGLE_APPLICATION_CREDENTIALS=
PLATFORM_ADMIN_EMAILS=pi@lab.example,admin@lab.example

# --- Frontend-only (move to react_frontend/.env.local or .env.production) ---
# Backend servers should use configs/.env.backend.example (no VITE_* lines).
# Tutorial: docs/FRONTEND_BACKEND_TUTORIAL.md
# VITE_API_URL=https://api.yourdomain.example
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=farkki-digital-notebook.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=farkki-digital-notebook
VITE_FIREBASE_STORAGE_BUCKET=farkki-digital-notebook.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=570069536455
VITE_FIREBASE_APP_ID=1:570069536455:web:4c4623a81262e6c4eef8e2
VITE_FIREBASE_MEASUREMENT_ID=G-24JLFQYRTG

# --- Supabase (hosted) — farkki digital platform / ccpvupyiqxubcupvtrtp ---
# See configs/SUPABASE_SETUP.md
SUPABASE_PROJECT_NAME=farkki digital platform
SUPABASE_PROJECT_REF=ccpvupyiqxubcupvtrtp
SUPABASE_REGION=eu-central-1
SUPABASE_URL=https://ccpvupyiqxubcupvtrtp.supabase.co
SUPABASE_POOLER_HOST=aws-1-eu-central-1.pooler.supabase.com
SUPABASE_POOLER_PORT=6543
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Database password (Settings → Database) — enables pooler URI for migrations/API
SUPABASE_DB_PASSWORD=
# When SUPABASE_DB_PASSWORD is unset, POSTGRES_CONN below is used (local dev).

# --- Supabase document sync (Postgres rows only — never Storage blobs) ---
# See docs/25_SUPABASE_SYNC_POLICY.md and configs/SUPABASE_SETUP.md
SUPABASE_SYNC_ENABLED=false
SUPABASE_MAX_TEXT_BYTES=50000
SUPABASE_SYNC_BATCH_SIZE=100
SUPABASE_SKIP_IMAGE_SYNC=true
SUPABASE_MAX_DB_MB=450

# Future: Firebase image metadata only (not file bytes)
FIREBASE_IMAGE_METADATA_ENABLED=false

# --- DataCloud WebDAV (primary research storage) — backend only; never expose to frontend ---
# Canonical base (files DAV):
DATACLOUD_WEBDAV_BASE_URL=https://datacloud.example.org/remote.php/dav/files/YOUR_USERNAME
DATACLOUD_ROOT=/farkkila/LAB-ASSISTANT-PLATFORM
DATACLOUD_USERNAME=
DATACLOUD_APP_PASSWORD=
# Legacy aliases (still read if canonical names unset):
# DATACLOUD_WEBDAV_URL=
# DATACLOUD_WEBDAV_USER=
# DATACLOUD_WEBDAV_PASSWORD=

# --- P-drive (secondary) — read mounted filesystem; no SMB auth in code unless added later ---
PDRIVE_ENABLED=false
PDRIVE_MOUNT_PATH=
PDRIVE_LOGICAL_ROOT=pdrive://
# Legacy alias:
# PDRIVE_SMB_ROOT=

# --- Sensitivity / clinical guardrails ---
ALLOW_PATIENT_DATA=false
DEFAULT_SENSITIVITY_MODE=documentation_only

# Embeddings: hash (offline default) or ollama (nomic-embed-text on Linux Docker)
# auto = use Ollama when reachable, else hash fallback (recommended for dev)
EMBEDDING_PROVIDER=auto
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_PROVIDER=hash
TEXT_EMBEDDING_MODEL=nomic-embed-text
TEXT_EMBEDDING_DIM=768
# When using nomic-embed-text via Ollama, set TEXT_EMBEDDING_DIM=768 and re-index:
#   python scripts/ingest/reindex_vectors.py
CHAT_USE_LEGACY_RAG=false
COPILOT_RETRIEVAL_CACHE_ENABLED=true
COPILOT_RETRIEVAL_CACHE_TTL_SEC=90
COPILOT_MIN_SIMILARITY=0.06
COPILOT_MIN_SIMILARITY_PROJECT_QUESTION=0.04
COPILOT_MIN_SIMILARITY_RESEARCH_QUESTION=0.08
RERANK_ENABLED=true
# RERANK_CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
#   python scripts/ingest/reindex_vectors.py

# Phase A/B copilot enhancements
CHUNK_FTS_ENABLED=true
RERANK_ENABLED=true
# Optional: pip install sentence-transformers + set model for cross-encoder rerank
# RERANK_CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
CHAT_SESSION_MEMORY=true
CHAT_SESSION_MAX_TURNS=12
SPATIAL_FEATURE_VECTOR_DIM=128

# --- Lab project storage root (SMB mount) — primary digitalization scan target ---
LAB_STORAGE_ROOT=

# --- Project digitalization / vault ingestion tuning ---
INGESTION_BATCH_SIZE=50
MAX_TEXT_FILE_MB=25
MAX_CHECKSUM_FILE_MB=50
ENABLE_OCR=false
ENABLE_TABLE_PREVIEW=true
ENABLE_AI_CLASSIFICATION=false
ENABLE_VECTOR_EMBEDDINGS=false
ENABLE_FULL_IMAGE_METADATA=false

# --- Autonomous OS processor (runs without Cursor IDE) ---
# See docs/28_AUTONOMOUS_PROCESSOR.md and scripts/ops/autonomous_processor.sh
PROCESSOR_AUTONOMOUS=true
PROCESSOR_INTERVAL_SEC=3600
PROCESSOR_STEPS=vault,digitalize,supabase_sync
# PROCESSOR_MAX_FILES=500

# --- Gemini Research Copilot chat (/api/chat) ---
# API key stays server-side only — never expose GEMINI_API_KEY to Vite/frontend.
# WARNING: Do not paste raw curl commands or bare URLs as unquoted lines — bash `source`
# will try to execute them and python-dotenv will warn on parse failures. Use KEY=value
# only, or keep curl examples fully commented (see GEMINI_cURL below).
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Optional debug reference (comments only — not loaded as an env var):
# GEMINI_cURL=curl "https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent" \
#   -H 'Content-Type: application/json' -H 'X-goog-api-key: YOUR_KEY_HERE' -X POST \
#   -d '{"contents":[{"parts":[{"text":"Explain how AI works in a few words"}]}]}'
# Optional chat-specific override (defaults to LLM_PROVIDER / shared llm_client)
CHAT_LLM_PROVIDER=gemini
CHAT_MAX_SOURCES=12
CHAT_STREAM_ENABLED=true
# Fallback order when primary provider fails (comma-separated)
# LLM_FALLBACK_PROVIDERS=gemini,groq,openai,openrouter,together,deepseek,ollama,mock

# --- Mac thin client + Tailscale to Linux Docker (recommended on Mac) ---
# Docker (Postgres, Qdrant, Ollama) runs on the Linux workstation — NOT on the Mac.
# EduVPN blocks peer traffic; use Tailscale mesh IPs (100.x.x.x). See docs/TAILSCALE_SETUP.md
# TAILSCALE_LINUX_IP=100.64.0.12
# OLLAMA_BASE_URL=http://100.64.0.12:11434/v1
# QDRANT_URL=http://100.64.0.12:6333
# POSTGRES_CONN=postgresql://farkki:farkki_dev_password@100.64.0.12:5432/farkki_ai
# start.sh auto-sets DOCKER_LOCAL=false when TAILSCALE_LINUX_IP is set.
# Test: ./scripts/network/mac_test_tailscale_ollama.sh
# Linux host stack: scripts/docker/start_linux_docker_stack.sh

# --- Mac thin client (no Docker Desktop — saves RAM) ---
# Run Docker on a Linux workstation instead; API + UI stay on the Mac.
# DOCKER_LOCAL=false
# DOCKER_AUTO_START=false
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_INTERNAL_TOKEN=<same token as Linux host>
# Optional SSH tunnel (safer than opening :11434 on LAN):
#   OLLAMA_SSH_HOST=user@linux-workstation ./scripts/llm/ollama_ssh_tunnel.sh
# Remote DB/vector (if stack runs on Linux):
# POSTGRES_CONN=postgresql://farkki:farkki_dev_password@<linux-ip>:5432/farkki_ai
# QDRANT_URL=http://<linux-ip>:6333
# Linux host: scripts/docker/start_linux_docker_stack.sh

# --- Docker service connection (health checks, auto-start, circuit breaker) ---
# start.sh runs scripts/dev/docker_bootstrap.sh before the API when DOCKER_LOCAL=true.
DOCKER_LOCAL=true
DOCKER_AUTO_START=true
DOCKER_WATCH_UNHEALTHY=false
DOCKER_COMPOSE_FILE=docker-compose.yml
DOCKER_HEALTH_INTERVAL_SEC=30
DOCKER_CIRCUIT_FAILURE_THRESHOLD=5
DOCKER_CIRCUIT_RECOVERY_SEC=30

# --- Ollama security (Docker internal + Caddy bearer proxy on 127.0.0.1:11434) ---
# Generate once: scripts/llm/generate_ollama_token.sh  (never commit real tokens)
OLLAMA_INTERNAL_TOKEN=
# Legacy alias (same value):
# OLLAMA_PROXY_TOKEN=

# --- Local Ollama (Docker — no cloud API key; models in Docker volume) ---
# Catalog: configs/ollama_research_models.json (HGSC, spatial biology, immunology)
# Start: docker compose up -d ollama ollama-proxy && scripts/llm/setup_ollama_local_llm.sh
# LLM_PROVIDER=ollama
# CHAT_LLM_PROVIDER=ollama
# OLLAMA_MODEL=qwen2.5:3b
# Switch OLLAMA_MODEL per task (see configs/ollama_research_models.json):
#   qwen2.5:3b — default fast chat; phi3:mini — fastest smoke tests
#   qwen2.5:7b-instruct — spatial biology / GeoMx / TLS synthesis
#   medllama2:7b — HGSC / oncology; meditron:7b / medgemma:4b — medical Q&A
#   llama3.1:8b — general lab assistant; mistral-nemo:12b — long batch synthesis
# OLLAMA_RESEARCH_MODELS=qwen2.5:3b,llama3.2:3b,phi3:mini,medgemma:4b,meditron:7b,medllama2:7b,qwen2.5:7b-instruct,llama3.1:8b,mistral-nemo:12b
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_INTERNAL_TOKEN=<from scripts/llm/generate_ollama_token.sh>
# LLM_FALLBACK_PROVIDERS=ollama,mock
# Pull override for setup script only: OLLAMA_MODELS=tag1,tag2 scripts/llm/setup_ollama_local_llm.sh

# Research Ollama catalog (cancer HGSC, spatial Visium/GeoMx, medical Q&A)
# Full list: configs/ollama_research_models.json
# Pull: docker compose up -d ollama && scripts/llm/setup_ollama_local_llm.sh
# Subset: OLLAMA_MODELS=qwen2.5:3b,medllama2:7b,qwen2.5:7b-instruct scripts/llm/setup_ollama_local_llm.sh
# OLLAMA_RESEARCH_MODELS=qwen2.5:3b,medgemma:4b,meditron:7b,medllama2:7b,qwen2.5:7b-instruct,llama3.1:8b,mistral-nemo:12b
# Task picks (set OLLAMA_MODEL):
#   cancer_oncology / immunotherapy / HGSC  -> medllama2:7b  (alt: meditron:7b, medgemma:4b)
#   spatial_biology / Visium / GeoMx / TLS  -> qwen2.5:7b-instruct  (alt: mistral-nemo:12b)
#   fast_eval / dev smoke tests             -> qwen2.5:3b

# --- Biomedical model Docker services (Linux workstation) ---
# Skip postgres/qdrant/ollama — already in docker-compose.yml
# Start: BIOMODEL_PROFILES=biomodels ./scripts/docker/setup_biomodels_docker.sh
# Mac thin client → set TAILSCALE_LINUX_IP URLs below
BIOMEDICAL_MODELS_GATEWAY_URL=http://127.0.0.1:8100
BIOMEDICAL_EMBEDDINGS_URL=http://127.0.0.1:8101
BIOMEDICAL_BIOGPT_URL=http://127.0.0.1:8102
BIOMEDICAL_TXGEMMA_URL=http://127.0.0.1:8103
BIOMEDICAL_GENEFORMER_URL=http://127.0.0.1:8110
BIOMEDICAL_SCGPT_URL=http://127.0.0.1:8111
BIOMEDICAL_SCPRINT_URL=http://127.0.0.1:8112
BIOMODEL_LAZY_LOAD=true
BIOMODELS_ENABLE_REGISTRY=false
HF_TOKEN=
# BIOMED_GATEWAY_BIND=0.0.0.0   # Linux: expose to Tailscale

# --- Intelligent Data Pad (section document editor) ---
# See docs/29_INTELLIGENT_DATAPAD.md
DATAPAD_EDIT_ENABLED=true
DATAPAD_AI_ENABLED=true
# LLM for heading suggestions and proofread (falls back to rules if unset)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-70b-versatile
# OPENAI_API_KEY=
# LLM_PROVIDER=groq

# --- Research Knowledge Base (Färkkilä lab AI brain) ---
# Apply sql/142_research_knowledge.sql; setup: scripts/document-library/setup_research_knowledge.sh
RESEARCH_KB_QDRANT_COLLECTION=research_knowledge
RESEARCH_KB_QDRANT_VECTOR_NAME=text
RESEARCH_KB_VECTOR_SIZE=768
RESEARCH_KB_EMBEDDING_PROVIDER=local
RESEARCH_KB_EMBEDDING_MODEL=hashing-fallback
RESEARCH_KB_RERANK_PROVIDER=none
RESEARCH_KB_CRAWL_DELAY_SECONDS=1.0
RESEARCH_KB_MAX_PUBLIC_PAGES=300
RESEARCH_KB_ENABLE_PLAYWRIGHT=false
RESEARCH_KB_ENABLE_PUBMED=true
RESEARCH_KB_ENABLE_CROSSREF=true
RESEARCH_KB_ENABLE_OPENALEX=false
RESEARCH_KB_ENABLE_SEMANTIC_SCHOLAR=false
RESEARCH_KB_COPYRIGHT_MODE=metadata_first

# --- Raw Knowledge Vault ingestion ---
# Set true to embed vault text chunks into Qdrant (uses shared vector_indexer embed path).
# After Linux reindex completes: VECTORIZATION_ENABLED=true, then VAULT_JSON_FALLBACK=false.
VECTORIZATION_ENABLED=false
VAULT_QDRANT_COLLECTION=vault_asset_chunks
VAULT_LOG_MAX_LINES=5000
VAULT_EXCEL_SAMPLE_ROWS=5
