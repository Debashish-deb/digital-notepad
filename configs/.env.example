# OMEIA Lab Assistant Platform — copy to .env (never commit real .env)
# Dev runs on local Postgres + Qdrant. Production: fill Firebase, Supabase, DataCloud when ready.
# Deploy topology: docs/26_PRODUCTION_DEPLOYMENT.md | checklist: configs/DEPLOYMENT_ENV.md

APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=*

# =============================================================================
# PRODUCTION (split hosts) — do not copy this block verbatim into one file
# =============================================================================
# Hostinger (app subdomain) — set in react_frontend/.env.production BEFORE npm run build:
#   VITE_API_URL=https://api.yourdomain.example
#   VITE_FIREBASE_API_KEY=...
#   VITE_FIREBASE_AUTH_DOMAIN=farkki-digital-notebook.firebaseapp.com
#   (other VITE_FIREBASE_* — see configs/FIREBASE_WEB_SETUP.md)
#
# University desktop backend — deploy/university-desktop/.env (see install_desktop_backend.sh):
#   APP_ENV=production
#   CORS_ORIGINS=https://app.yourdomain.example
#   PLATFORM_AUTH_DISABLED=false
#   FIREBASE_SERVICE_ACCOUNT_PATH=/opt/omeia/secrets/firebase-adminsdk.json
#   SUPABASE_* and SUPABASE_DB_PASSWORD (backend only — never Vite)
#   DATACLOUD_* (backend only — never Vite)
#
# Example layout:
#   https://app.yourdomain.example  → Hostinger static dist/
#   https://api.yourdomain.example  → desktop Caddy/nginx → 127.0.0.1:8000
# =============================================================================

# --- Local dev database (default until Supabase hosted is provided) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=farkki_ai
POSTGRES_USER=farkki
POSTGRES_PASSWORD=farkki_dev_password
POSTGRES_CONN=postgresql://farkki:farkki_dev_password@localhost:5432/farkki_ai

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=farkki_dev_password

# --- Repo paths (local data lives OUTSIDE git — never commit database/) ---
# Leave OMEIA_REPO_ROOT empty to use this repository root.
OMEIA_REPO_ROOT=
# Sibling folder after migration (default): ../OMEIA-database
# Or set OMEIA_DATABASE_ROOT / DATABASE_ROOT to an absolute path.
DATABASE_ROOT=../OMEIA-database
PROJECTS_ROOT=

# --- Firebase Auth: Email/Password only (NO Google Sign-In) ---
# Project: Farkki-digital-notebook / farkki-digital-notebook (570069536455)
# Console owner (for Firebase/Google Cloud login only — never commit password):
# FIREBASE_CONSOLE_EMAIL=farkkilalab@gmail.com
# Lab users sign in with @helsinki.fi on the platform, not this Gmail.
# Enable Email/Password in Firebase Console → Authentication → Sign-in method.
# Disable Google and other OAuth providers.
PLATFORM_AUTH_DISABLED=true
FIREBASE_PROJECT_NAME=Farkki-digital-notebook
FIREBASE_PROJECT_ID=farkki-digital-notebook
FIREBASE_PROJECT_NUMBER=570069536455
FIREBASE_AUTH_DOMAIN=farkki-digital-notebook.firebaseapp.com
FIREBASE_STORAGE_BUCKET=farkki-digital-notebook.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=570069536455
FIREBASE_MEASUREMENT_ID=G-24JLFQYRTG
# Web app OMEIA.AI — see configs/FIREBASE_WEB_SETUP.md for full console snippet
FIREBASE_WEB_APP_NICKNAME=OMEIA.AI
FIREBASE_WEB_APP_ID=1:570069536455:web:4c4623a81262e6c4eef8e2
# Web API key — set in configs/.env only (not committed)
FIREBASE_WEB_API_KEY=
# Server: service account JSON for token verification (NOT user Google login).
# Copy to configs/secrets/firebase-adminsdk.json — never commit, never put under public/.
FIREBASE_SERVICE_ACCOUNT_PATH=
# Legacy alias (same path):
GOOGLE_APPLICATION_CREDENTIALS=
PLATFORM_ADMIN_EMAILS=anniina.farkkila@helsinki.fi,debashish.deb@helsinki.fi,joonas.jukonen@helsinki.fi

# Vite frontend (local dev: react_frontend/.env.local — prod: .env.production on Hostinger CI)
# Production API base (required on Hostinger build; dev falls back to :8000 on same host)
# VITE_API_URL=https://api.yourdomain.example
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=farkki-digital-notebook.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=farkki-digital-notebook
VITE_FIREBASE_STORAGE_BUCKET=farkki-digital-notebook.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=570069536455
VITE_FIREBASE_APP_ID=1:570069536455:web:4c4623a81262e6c4eef8e2
VITE_FIREBASE_MEASUREMENT_ID=G-24JLFQYRTG

# --- Supabase (hosted) — farkki digital platform / ccpvupyiqxubcupvtrtp ---
# See configs/SUPABASE_SETUP.md
SUPABASE_PROJECT_NAME=farkki digital platform
SUPABASE_PROJECT_REF=ccpvupyiqxubcupvtrtp
SUPABASE_REGION=eu-central-1
SUPABASE_URL=https://ccpvupyiqxubcupvtrtp.supabase.co
SUPABASE_POOLER_HOST=aws-1-eu-central-1.pooler.supabase.com
SUPABASE_POOLER_PORT=6543
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Database password (Settings → Database) — enables pooler URI for migrations/API
SUPABASE_DB_PASSWORD=
# When SUPABASE_DB_PASSWORD is unset, POSTGRES_CONN below is used (local dev).

# --- Supabase document sync (Postgres rows only — never Storage blobs) ---
# See docs/25_SUPABASE_SYNC_POLICY.md and configs/SUPABASE_SETUP.md
SUPABASE_SYNC_ENABLED=false
SUPABASE_MAX_TEXT_BYTES=50000
SUPABASE_SYNC_BATCH_SIZE=100
SUPABASE_SKIP_IMAGE_SYNC=true
SUPABASE_MAX_DB_MB=450

# Future: Firebase image metadata only (not file bytes)
FIREBASE_IMAGE_METADATA_ENABLED=false

# --- DataCloud WebDAV (primary research storage) — backend only; never expose to frontend ---
# Canonical base (files DAV):
DATACLOUD_WEBDAV_BASE_URL=https://datacloud.helsinki.fi/remote.php/dav/files/debdeba%40helsinki.fi
DATACLOUD_ROOT=/farkkila/LAB-ASSISTANT-PLATFORM
DATACLOUD_USERNAME=
DATACLOUD_APP_PASSWORD=
# Legacy aliases (still read if canonical names unset):
# DATACLOUD_WEBDAV_URL=
# DATACLOUD_WEBDAV_USER=
# DATACLOUD_WEBDAV_PASSWORD=

# --- P-drive (secondary) — read mounted filesystem; no SMB auth in code unless added later ---
PDRIVE_ENABLED=false
PDRIVE_MOUNT_PATH=
PDRIVE_LOGICAL_ROOT=pdrive://
# Legacy alias:
# PDRIVE_SMB_ROOT=

# --- Sensitivity / clinical guardrails ---
ALLOW_PATIENT_DATA=false
DEFAULT_SENSITIVITY_MODE=documentation_only

TEXT_EMBEDDING_MODEL=local-demo-embedding
TEXT_EMBEDDING_DIM=384
SPATIAL_FEATURE_VECTOR_DIM=128

# --- Lab project storage root (SMB mount) — primary digitalization scan target ---
LAB_STORAGE_ROOT=

# --- Project digitalization / vault ingestion tuning ---
INGESTION_BATCH_SIZE=50
MAX_TEXT_FILE_MB=25
MAX_CHECKSUM_FILE_MB=50
ENABLE_OCR=false
ENABLE_TABLE_PREVIEW=true
ENABLE_AI_CLASSIFICATION=false
ENABLE_VECTOR_EMBEDDINGS=false
ENABLE_FULL_IMAGE_METADATA=false

# --- Autonomous OS processor (runs without Cursor IDE) ---
# See docs/28_AUTONOMOUS_PROCESSOR.md and scripts/autonomous_processor.sh
PROCESSOR_AUTONOMOUS=true
PROCESSOR_INTERVAL_SEC=3600
PROCESSOR_STEPS=vault,digitalize,supabase_sync
# PROCESSOR_MAX_FILES=500

# --- Intelligent Data Pad (section document editor) ---
# See docs/29_INTELLIGENT_DATAPAD.md
DATAPAD_EDIT_ENABLED=true
DATAPAD_AI_ENABLED=true
# LLM for heading suggestions and proofread (falls back to rules if unset)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-70b-versatile
# OPENAI_API_KEY=
# LLM_PROVIDER=groq

# --- Raw Knowledge Vault ingestion ---
# Set true to embed vault text chunks into Qdrant (uses llm_client hashed embed; no silent stubs).
VECTORIZATION_ENABLED=false
VAULT_QDRANT_COLLECTION=vault_asset_chunks
VAULT_LOG_MAX_LINES=5000
VAULT_EXCEL_SAMPLE_ROWS=5
