Bootstrap: docker
From: rocm/tensorflow:rocm6.3.3-py3.10-tf2.17-dev

%labels
    Author Debashish Deb
    Description DeepCell Mesmer for LUMI MI250X using ROCm 6.3 and TensorFlow 2.17
    DeepCell_Version 0.13.0+rocm
    TensorFlow_Version 2.17.0
    ROCm_Version 6.3.3

%files
    deepcell-tf/deepcell-tf /opt/deepcell-tf

%environment
    export LC_ALL=C
    export LANG=C
    export PYTHONUNBUFFERED=1
    export PYTHONDONTWRITEBYTECODE=1
    export TF_USE_LEGACY_KERAS=1
    export TF_CPP_MIN_LOG_LEVEL=2
    export TF_ENABLE_ONEDNN_OPTS=0
    export TF_ENABLE_MLIR_BRIDGE=0
    export ROCM_PATH=/opt/rocm
    export HIP_DEVICE_LIB_PATH=/opt/rocm/lib/llvm/lib/clang/18/lib/amdgcn/bitcode
    export LD_LIBRARY_PATH=/opt/rocm/lib:/opt/rocm/lib64
    export HSA_XNACK=0
    export HSA_ENABLE_SDMA=0
    export MIOPEN_DEBUG_DISABLE_FIND_DB=1
    export MIOPEN_FIND_MODE=NORMAL
    export DEEPCELL_CACHE_DIR=/tmp/.deepcell
    export XDG_CACHE_HOME=/tmp/xdg-cache
    export XDG_CONFIG_HOME=/tmp/xdg-config
    export MPLCONFIGDIR=/tmp/matplotlib

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates \
        libgl1 \
        libglib2.0-0 \
        libsm6 \
        libxext6 \
        libxrender1
    rm -rf /var/lib/apt/lists/*

    python3.10 -m pip install --no-cache-dir --upgrade pip setuptools wheel

    # Install the scientific stack first. Packages that declare a dependency
    # named "tensorflow" are installed with --no-deps below so pip cannot
    # replace AMD's tensorflow-rocm distribution with CPU TensorFlow.
    python3.10 -m pip install --no-cache-dir \
        numpy==1.26.4 \
        cython==0.29.37 \
        scipy==1.13.1 \
        pandas==2.2.3 \
        scikit-image==0.24.0 \
        scikit-learn==1.5.2 \
        opencv-python-headless==4.10.0.84 \
        matplotlib==3.9.4 \
        networkx==3.4.2 \
        pillow==11.1.0 \
        pydot==1.4.2 \
        lxml==5.3.0 \
        requests==2.32.3 \
        tqdm==4.67.1 \
        tifffile==2024.9.20 \
        zarr==2.18.3 \
        numcodecs==0.13.1 \
        deeptile==2.0.10 \
        dask==2024.12.1 \
        cloudpickle==3.1.1 \
        fsspec==2024.12.0 \
        packaging==24.2 \
        partd==1.4.2 \
        pyyaml==6.0.2 \
        toolz==1.0.0 \
        locket==1.0.0 \
        click==8.1.8 \
        importlib_metadata==8.5.0 \
        zipp==3.21.0 \
        protobuf==4.25.5

    python3.10 -m pip install --no-cache-dir --no-deps \
        tf-keras==2.17.0 \
        spektral==1.3.1 \
        DeepCell-Toolbox==0.12.1 \
        DeepCell-Tracking==0.6.5

    sed -i "s/'tf-keras~=2.18'/'tf-keras~=2.17'/" /opt/deepcell-tf/setup.py
    python3.10 -m pip install --no-cache-dir --no-deps /opt/deepcell-tf

    mkdir -p \
        /workspace \
        /tmp/.deepcell \
        /tmp/xdg-cache \
        /tmp/xdg-config \
        /tmp/matplotlib \
        /tmp/miopen-cache

    # A CPU TensorFlow wheel here would make GPU jobs silently run on CPUs.
    python3.10 - <<'PY'
import importlib.metadata as metadata
import tensorflow as tf

assert metadata.version("tensorflow-rocm").startswith("2.17.")
assert tf.sysconfig.get_build_info().get("is_rocm_build") is True
from deepcell.applications import Mesmer
from deeptile import lift, load
print("ROCm TensorFlow and Mesmer imports OK")
PY

%runscript
    exec /usr/local/bin/python3.10 "$@"

%test
    python3.10 - <<'PY'
import importlib.metadata as metadata
import tensorflow as tf
from deepcell.applications import Mesmer
from deeptile import lift, load

print("tensorflow-rocm:", metadata.version("tensorflow-rocm"))
print("DeepCell:", metadata.version("deepcell"))
print("ROCm build:", tf.sysconfig.get_build_info().get("is_rocm_build"))
assert tf.sysconfig.get_build_info().get("is_rocm_build") is True
PY
