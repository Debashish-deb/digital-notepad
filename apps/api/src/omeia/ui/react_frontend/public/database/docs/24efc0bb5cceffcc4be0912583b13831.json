{"document_id":"24efc0bb5cceffcc4be0912583b13831","filename":"FF_DNA_extraction_Maxwell_ElinaNiemelä.docx","relative_path":"23_ovaHRDscar_OncosysOVA/Manuscript/Manuscript sections from co-authors/FF_DNA_extraction_Maxwell_ElinaNiemelä.docx","section":"11_23_ovahrdscar_oncosysova-20260602t172010z-3-001","has_text":true,"chunk_count":1,"full_text":"DNA from fresh-frozen tissue samples was extracted using Maxwell CSC Genomic DNA automated bead-based extraction kit. Briefly, up to 50 mg of tissue was shredded using a scalpel, transferred to a clean Eppendorf tube, and lysed according to the manufacturer’s instructions for 2 hours on a thermal mixer set to 56°C and 1400 rpm. Automated extraction was performed according to instructions and DNA was eluted to 100 µl low-EDTA TE. DNA quality was monitored using spectrophotometric and fluorometric assays.","metadata":{"source":{"filename":"FF_DNA_extraction_Maxwell_ElinaNiemelä.docx","stem":"FF_DNA_extraction_Maxwell_ElinaNiemelä","extension":".docx","relative_path":"23_ovaHRDscar_OncosysOVA/Manuscript/Manuscript sections from co-authors/FF_DNA_extraction_Maxwell_ElinaNiemelä.docx","absolute_path":"/Users/debashishdeb/Downloads/OMEIA-database/projects/23_ovaHRDscar_OncosysOVA-20260602T172010Z-3-001/23_ovaHRDscar_OncosysOVA/Manuscript/Manuscript sections from co-authors/FF_DNA_extraction_Maxwell_ElinaNiemelä.docx","size_bytes":14295,"size_human":"13.96 KB","modified":"2026-02-11T04:18:22","mime_type":"application/vnd.openxmlformats-officedocument.wordprocessingml.document","hashes":{"md5":"693f9e2d4d17da15f750df3b10c957a3"}},"classification":{"family":"word","extension":".docx","mime_type":"application/vnd.openxmlformats-officedocument.wordprocessingml.document","extractor":"python-docx","status":"ok"},"extraction_metadata":{"paragraph_count":1,"table_count":0,"core_properties":{"title":"","subject":"","author":"Niemelä Elina","keywords":"","created":"2026-01-27T13:24:00+00:00","modified":"2026-01-27T13:37:00+00:00","las